# ====================================================================
# Environment template for LOCAL (Node) development.
# Copy to .env and fill in the values:   cp .env.example .env
# (For Docker, use .env.docker.example → .env.docker instead.)
# Never commit .env — it is git-ignored.
# ====================================================================

# ---- Database (required) ----
# Local PostgreSQL connection string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/quvenza_db?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/quvenza_db?schema=public"

# ---- JWT (required — generate strong secrets: openssl rand -base64 48) ----
JWT_SECRET=change-me-min-32-chars-secret
JWT_REFRESH_SECRET=change-me-different-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Public URLs (visible to the browser) ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_APP_NAME=Quvenza

# ---- Cloudinary (optional — product image uploads; leave empty to use placeholders) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Telegram (optional — new-order notifications) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Verification (optional) ----
NEXT_PUBLIC_GOOGLE_VERIFICATION=
NEXT_PUBLIC_FB_VERIFICATION=
