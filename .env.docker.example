# ====================================================================
# قالب متغيرات تشغيل المشروع بـ Docker.
# انسخه إلى .env.docker واملأ القيم:   cp .env.docker.example .env.docker
# ملاحظة: DATABASE_URL و DIRECT_URL مضبوطة تلقائياً في docker-compose.yml
#         (تشير إلى خدمة postgres) — لا حاجة لوضعها هنا.
# ====================================================================

# ---- JWT (ولّد أسرار قوية: openssl rand -base64 48) ----
JWT_SECRET=change-me-min-32-chars-secret
JWT_REFRESH_SECRET=change-me-different-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- روابط عامة (يراها المتصفح) ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_APP_NAME=SoftoDev

# ---- Cloudinary (اختياري — للصور؛ اتركها فارغة للتطوير) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Telegram (اختياري — لإشعارات الطلبات) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- التحقق (اختياري) ----
NEXT_PUBLIC_GOOGLE_VERIFICATION=
NEXT_PUBLIC_FB_VERIFICATION=
